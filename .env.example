# BasaltRouter environment configuration
# Copy to .env and adjust for local development.

# --- Server ---
BASALT_SERVER_PORT=8080
BASALT_SERVER_TLS_ENABLED=false
BASALT_SERVER_TLS_CERT_PATH=
BASALT_SERVER_TLS_KEY_PATH=
BASALT_SERVER_READ_TIMEOUT=30s
BASALT_SERVER_WRITE_TIMEOUT=30s

# --- Database (required) ---
BASALT_DATABASE_DSN=postgres://basalt:basalt@localhost:5432/basalt?sslmode=disable
BASALT_DATABASE_MAX_CONNS=25
BASALT_DATABASE_MIN_CONNS=5
BASALT_DATABASE_MAX_CONN_LIFETIME=30m
BASALT_DATABASE_HEALTH_CHECK_PERIOD=30s

# --- Redis (required) ---
BASALT_REDIS_ADDR=localhost:6379
BASALT_REDIS_PASSWORD=
BASALT_REDIS_TLS_ENABLED=false
BASALT_REDIS_TLS_CA_PATH=
BASALT_REDIS_POOL_SIZE=10

# --- Encryption (required) ---
# Mode: local | kms
BASALT_ENCRYPTION_MODE=local
BASALT_ENCRYPTION_LOCAL_KEY_PATH=./secrets/local.key
BASALT_ENCRYPTION_KMS_KEY_ID=

# --- Logging ---
BASALT_LOG_LEVEL=info
BASALT_LOG_FORMAT=json
BASALT_LOG_OUTPUT=stdout

# --- OpenTelemetry ---
BASALT_TELEMETRY_ENABLED=true
BASALT_TELEMETRY_SERVICE_NAME=gateway
BASALT_TELEMETRY_EXPORTER=stdout

# --- Docker Compose overrides (per service) ---
# Gateway:  BASALT_SERVER_PORT=8080
# API:      BASALT_SERVER_PORT=8081
# Worker:   BASALT_SERVER_PORT=8082

# --- pgAdmin (optional, profile tools) ---
PGADMIN_DEFAULT_EMAIL=admin@basalt.local
PGADMIN_DEFAULT_PASSWORD=admin
